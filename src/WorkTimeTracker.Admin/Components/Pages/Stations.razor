@page "/stations"
@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Станции</PageTitle>

<h1>Станции</h1>

@if (rows is null)
{
    <p><em>Загрузка...</em></p>
}
else if (rows.Count == 0)
{
    <p>Станций пока нет. Запустите агент на одной из машин — она появится при первом heartbeat'е.</p>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>Hostname</th>
                <th>Текущий пользователь</th>
                <th>WTS session</th>
                <th>OS</th>
                <th>Версия агента</th>
                <th>Heartbeat</th>
                <th>Live</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in rows)
            {
                var liveActive = r.LiveViewUntil is { } u && u > DateTime.UtcNow;
                <tr>
                    <td><strong>@r.Hostname</strong></td>
                    <td>@(r.CurrentSamAccountName ?? "—")</td>
                    <td>@(r.CurrentSessionId?.ToString() ?? "—")</td>
                    <td>@(r.OsVersion ?? "—")</td>
                    <td>@(r.AgentVersion ?? "—")</td>
                    <td>@FormatHeartbeat(r.LastHeartbeatAt)</td>
                    <td>
                        @if (liveActive)
                        {
                            <span class="badge-live">live до @(r.LiveViewUntil!.Value.ToLocalTime().ToString("HH:mm"))</span>
                        }
                        else
                        {
                            <span class="muted">—</span>
                        }
                    </td>
                    <td class="actions">
                        <a class="btn-link" href="/watch/@r.Hostname">Watch</a>
                        <button class="btn-link" @onclick="() => ShowShadow(r)">RDP shadow</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (selectedShadow is not null)
    {
        <div class="callout">
            <strong>Команда RDP shadow для @selectedShadow.Hostname (выполнить на админ-машине):</strong>
            <pre>@selectedShadow.Command</pre>
            <small>Текущий пользователь на хосте: @(selectedShadow.User ?? "неизвестен"), WTS session id: @selectedShadow.SessionId.<br/>
            Требует политики "Set rules for remote control of Remote Desktop Services user sessions" → Full Control without user's permission, заданной для админ-группы. Без этой политики Windows запросит разрешение у пользователя.</small>
        </div>
    }
}

@code {
    private record Row(
        string Hostname,
        string? OsVersion,
        string? AgentVersion,
        DateTime? LastHeartbeatAt,
        int? CurrentSessionId,
        string? CurrentSamAccountName,
        DateTime? LiveViewUntil);

    private record ShadowInfo(string Hostname, string Command, int SessionId, string? User);

    private List<Row>? rows;
    private ShadowInfo? selectedShadow;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        rows = await db.ServerHosts
            .OrderByDescending(h => h.LastHeartbeatAt)
            .Select(h => new Row(
                h.Hostname,
                h.OsVersion,
                h.AgentVersion,
                h.LastHeartbeatAt,
                h.CurrentSessionId,
                h.CurrentSamAccountName,
                h.LiveViewUntil))
            .ToListAsync();
    }

    private static string FormatHeartbeat(DateTime? at)
    {
        if (at is null) return "никогда";
        var ago = DateTime.UtcNow - at.Value;
        if (ago.TotalSeconds < 30) return "только что";
        if (ago.TotalMinutes < 60) return $"{(int)ago.TotalMinutes} мин назад";
        if (ago.TotalHours < 24) return $"{(int)ago.TotalHours} ч назад";
        return at.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }

    private void ShowShadow(Row r)
    {
        var sid = r.CurrentSessionId ?? 1;
        var cmd = $"mstsc /shadow:{sid} /v:{r.Hostname} /control /noconsentprompt";
        selectedShadow = new ShadowInfo(r.Hostname, cmd, sid, r.CurrentSamAccountName);
    }
}
